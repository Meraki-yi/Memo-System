# ==================== 应用配置 ====================
# 应用名称
APP_NAME=Memo System
# 应用版本
VERSION=1.0.0
# 调试模式 (True/False)
DEBUG=False
# 应用端口（对外暴露）
APP_PORT=8000

# ==================== 安全配置 ====================
# 访问密码（请设置强密码）
ACCESS_PASSWORD=your_secure_password_here

# ==================== 数据库配置 ====================
# MySQL root 密码（请设置强密码）
MYSQL_ROOT_PASSWORD=your_root_password_here
# 数据库名称
MYSQL_DATABASE=memo_system
# MySQL 用户名
MYSQL_USER=memo_user
# MySQL 密码（请设置强密码）
MYSQL_PASSWORD=memo_password_here
# MySQL 对外端口（可选，默认 3306）
MYSQL_PORT=3306

# ==================== CORS 配置 ====================
# 允许的源（多个用逗号分隔）
ALLOWED_ORIGINS=*
# 允许的方法
ALLOWED_METHODS=*
# 允许的请求头
ALLOWED_HEADERS=*
